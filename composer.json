{
    "name": "goldfinch/silverstripe-jsontext",
    "description": "JSON storage, querying and modification.",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "silverstripe",
        "json",
        "dbfield",
        "query",
        "multi",
        "multivalue",
        "multivaluefield",
        "text",
        "JSONPath",
        "Postgres"
    ],
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Russell Michell",
            "homepage": "http://theruss.com/",
            "email": "russ@theruss.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "silverstripe/framework": "^6",
        "peekmo/jsonpath": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "support": {
        "issues": "https://github.com/goldfinch/silverstripe-jsontext/issues"
    },
    "suggest": {
        "silverstripe/cms": "Use silverstripe/cms package if you want to write to JSON-backed DB fields via the CMS module's UI"
    },
    "extra": {
        "installer-name": "jsontext"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
